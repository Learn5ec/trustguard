# TrustGuard AI Optional Environment Variables

# GitHub token for higher rate limits (optional - only used server-side / in vite.config.ts)
# Generate a Personal Access Token (classic or fine-grained) at https://github.com/settings/tokens
# ⚠️  Do NOT use VITE_ prefix — that would inline the value into the public client bundle.
DEFAULT_GITHUB_TOKEN=

# NVD API key (optional - improves rate limits for NIST NVD API, reserved for future use)
# Request an API key at https://nvd.nist.gov/developers/request-an-api-key
# ⚠️  Do NOT use VITE_ prefix — that would inline the value into the public client bundle.
DEFAULT_NVD_KEY=

# App version (injected by Vite at build time usually, can be manually set for dev)
VITE_APP_VERSION=1.0.0-dev

# Analytics (optional)
VITE_PLAUSIBLE_DOMAIN=

# -----------------------------------------------------------------------------
# ⚠️ SECURITY WARNING ⚠️
# Note: LLM API Keys (OpenAI, Anthropic, etc.) MUST NOT be put in this file! 
# They should only be configured via the TrustGuard AI UI so they are securely stored
# in the browser's sessionStorage and NEVER persisted to disk or git.
# -----------------------------------------------------------------------------
